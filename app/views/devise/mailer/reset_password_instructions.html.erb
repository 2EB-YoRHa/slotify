<!DOCTYPE html>
<html>
  <body style="font-family: Arial, sans-serif; background: #f8fafc; padding: 32px;">
    <div style="max-width: 600px; margin: 0 auto; background: #ffffff; border: 1px solid #e2e8f0; border-radius: 16px; padding: 32px;">
      <h1 style="margin: 0; color: #0f172a;">
        Reset your Slotify password
      </h1>

      <p style="color: #475569; line-height: 1.6;">
        Hello <strong><%= @resource.email %></strong>,
      </p>

      <p style="color: #475569; line-height: 1.6;">
        Someone requested a link to reset your password. You can update it using the button below.
      </p>

      <p style="margin: 32px 0;">
        <a
          href="<%= edit_user_password_url(reset_password_token: @token) %>"
          style="background: #22d3ee; color: white; text-decoration: none; padding: 14px 22px; border-radius: 10px; font-weight: bold; display: inline-block;"
        >
          Reset Password
        </a>
      </p>

      <p style="color: #475569; line-height: 1.6;">
        If the button does not work, copy and paste this link into your browser:
      </p>

      <p style="word-break: break-all; color: #0891b2; font-size: 14px;">
        <%= edit_user_password_url(reset_password_token: @token) %>
      </p>

      <hr style="border: none; border-top: 1px solid #e2e8f0; margin: 32px 0;">

      <p style="color: #94a3b8; font-size: 12px;">
        If you did not request this password reset, you can ignore this email.
        Your password will not change until you create a new one.
      </p>
    </div>
  </body>
</html>